// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`


generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int     @id @default(autoincrement())
  nombres           String
  apellido_paterno  String
  apellido_materno  String
  dni               String  @unique
  celular           String
  email             String  @unique

  team              Team?
}

model Admin {
  id           Int    @id @default(autoincrement())
  organizador  String
  correo       String @unique
  nro_celular  String
  dni          String @unique
  password     String
}

model ProfessionalCollege {
  id          Int    @id @default(autoincrement())
  nombre      String @unique
  abreviatura String? @unique

  teams       Team[]
}

model Category {
  id          Int    @id @default(autoincrement())
  nombre      String @unique

  teams       Team[]
}

model Team {
  id                     Int                 @id @default(autoincrement())
  nombre                 String
  categoria              String?
  userId                 Int                 @unique
  categoryId             Int?
  professionalCollegeId  Int?
  playerRegistrationToken String?
  playerRegistrationTokenExpiresAt DateTime?
  registrationClosed     Boolean             @default(false)

  user                   User                @relation(fields: [userId], references: [id])
  category               Category?           @relation(fields: [categoryId], references: [id])
  professionalCollege    ProfessionalCollege? @relation(fields: [professionalCollegeId], references: [id])

  players                Player[]
}

model Player {
  id                Int     @id @default(autoincrement())
  nombres           String  @default("")
  apellido_paterno  String  @default("")
  apellido_materno  String  @default("")
  dni               String  @unique
  nro_colegiatura   String?
  edad              Int?
  foto_url          String?

  teamId            Int
  team              Team    @relation(fields: [teamId], references: [id])
}
